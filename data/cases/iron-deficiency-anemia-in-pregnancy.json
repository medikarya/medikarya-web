        "treatment_plan": [
            "Calculate total iron deficit using Ganzoni formula",
            "Administer IV Iron Sucrose as per calculated dose",
            "200 mg diluted in 100 mL normal saline over 30 minutes",
            "Repeat on alternate days until total dose achieved",
            "Dietary counselling for iron-rich foods",
            "Vitamin C supplementation",
            "Avoid tea/coffee with meals",
            "Repeat Hb after 3 weeks"
        ],
